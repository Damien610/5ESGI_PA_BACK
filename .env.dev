# Configuration de la base de données
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=app_db_dev
POSTGRES_HOST=db_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://dev:dev@db_dev:5432/app_db_dev
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://dev:dev@db_dev:5432/app_db_dev

# Clé secrète pour l'application
SECRET_KEY=your_secret_key

# Mode debug
DEBUG=True
